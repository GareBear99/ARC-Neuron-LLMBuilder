# EditorConfig — consistent formatting across editors and contributors.
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{py,pyi}]
indent_style = space
indent_size = 4
max_line_length = 100

[*.{json,yaml,yml,toml}]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false   # trailing whitespace significant for hard line breaks

[Makefile]
indent_style = tab

[*.{sh,bash}]
indent_style = space
indent_size = 2

[*.jsonl]
# Each line is an independent JSON value; do not allow whitespace trimming
# to alter string content.
trim_trailing_whitespace = false
